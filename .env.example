# Copy to .env and fill in real values (.env is gitignored).
# In Portainer, set these as stack environment variables instead.

# Sensor IP
WC_DEVICE=192.168.1.60

# Web Push VAPID keypair. Generate once with:
#   npx web-push generate-vapid-keys
# (or any P-256 keypair in base64url form). Keep the private key secret.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
