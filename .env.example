# Copy to .env and fill in real values (.env is gitignored).
# In Portainer, set these as stack environment variables instead.

# Sensor IP
WC_DEVICE=192.168.1.60

# Unique per stack when running prod + test on the same host — prefixes
# container names and image tags (e.g. "wc" for prod, "test-wc" for test).
STACK_PREFIX=wc

# Published host port for the web page — must also differ per stack.
WEB_PORT=8080

# Web Push VAPID keypair. Generate once with:
#   npx web-push generate-vapid-keys
# (or any P-256 keypair in base64url form). Keep the private key secret.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
